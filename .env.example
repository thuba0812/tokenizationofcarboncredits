# ─── Supabase ────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# ─── Smart Contract Addresses ────────────────────────────
# Update these after deploying contracts
VITE_CARBON_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
VITE_MOCK_USDT_ADDRESS=0x0000000000000000000000000000000000000000
VITE_MARKETPLACE_ADDRESS=0x0000000000000000000000000000000000000000

# ─── Network Config ─────────────────────────────────────
# Hardhat Local: 31337, Sepolia: 11155111, BSC Testnet: 97
VITE_CHAIN_ID=11155111
VITE_NETWORK_NAME=Sepolia Testnet
VITE_BLOCK_EXPLORER_URL=https://sepolia.etherscan.io
VITE_RPC_URL=https://rpc2.sepolia.org

# ─── Deployment (NOT exposed to frontend) ───────────────
PRIVATE_KEY=your_deployer_private_key
